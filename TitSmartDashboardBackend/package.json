      { "from": "run_video.sh", "to": "run_video.sh" },
      {
        "from": "build/Release/hikvision.node",
        "to": "build/Release/hikvision.node"
      },
      {
        "from": "../lib",
        "to": "lib"
      },
      {
        "from": "build/icon.png",
